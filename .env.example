# Copy to .env and adjust. Load it however you prefer (e.g. `set -a; . ./.env; set +a`)
# or with python-dotenv. The code itself reads plain environment variables.

# --- Semantic Scholar ---
# Optional. Without a key you share the public ~1 req/sec pool.
S2_API_KEY=your_key_here
S2_MIN_REQUEST_INTERVAL=1.1

# GROQ API
GROQ_API_KEY=<your key>

# --- Database ---
DATABASE_URL=postgresql+psycopg2://postgres:postgres@localhost:5432/rag

# --- Embeddings (EMBEDDING_DIM MUST match the model output dimension) ---
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2
EMBEDDING_DIM=384

# --- Chunking (characters) ---
CHUNK_SIZE=1200
CHUNK_OVERLAP=200

# --- Ingestion ---
PAPERS_PER_CATEGORY=100
OPEN_ACCESS_ONLY=true
MIN_CITATION_COUNT=0
# YEAR_RANGE=2018-2026
PDF_DIR=./data/pdfs
DOWNLOAD_PDFS=true
